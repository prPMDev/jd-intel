{
  "name": "jd-intel-mcp",
  "version": "0.1.0",
  "description": "MCP server for jd-intel. Your AI assistant fetches and reasons over full job descriptions, no copy-paste.",
  "type": "module",
  "main": "server.js",
  "bin": {
    "jd-intel-mcp": "./cli.js"
  },
  "files": [
    "cli.js",
    "server.js",
    "tools.js",
    "resources.js",
    "envelope.js",
    "errors.js",
    "descriptions.js",
    "install.js",
    "README.md"
  ],
  "scripts": {
